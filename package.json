{
  "name": "oriclaw-backend",
  "version": "1.0.0",
  "description": "OriClaw backend provisioning API — auto-creates DigitalOcean Droplets for OpenClaw customers",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "ops:openclaw": "node scripts/openclaw-ops.mjs",
    "ops:openclaw:status": "node scripts/openclaw-ops.mjs status",
    "ops:openclaw:doctor": "node scripts/openclaw-ops.mjs doctor",
    "ops:openclaw:channels": "node scripts/openclaw-ops.mjs channels",
    "ops:openclaw:logs": "node scripts/openclaw-ops.mjs logs",
    "ops:openclaw:self-heal": "node scripts/openclaw-ops.mjs self-heal",
    "ops:openclaw:whatsapp-relink": "node scripts/openclaw-ops.mjs whatsapp-relink",
    "smoke": "node scripts/smoke-check.mjs",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.3",
    "axios": "^1.6.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "selfsigned": "^3.0.1",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
